{
    "name": "dcplibrary/requests",
    "description": "Suggest for Purchase package for the Daviess County Public Library — patron form + staff admin UI",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/cache": "^12.0",
        "illuminate/auth": "^12.0",
        "livewire/livewire": "^3.0|^4.0",
        "blashbrook/papiclient": "*",
        "dcplibrary/entra-sso": "^1.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload-dev": {
        "psr-4": {
            "Dcplibrary\\Requests\\Tests\\": "tests/"
        }
    },
    "autoload": {
        "psr-4": {
            "Dcplibrary\\Requests\\": "src/",
            "Dcplibrary\\Requests\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dcplibrary\\Requests\\RequestsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
