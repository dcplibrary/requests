{
    "name": "dcplibrary/sfp",
    "description": "Suggest for Purchase package for DC Public Library — patron form + staff admin UI",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/cache": "^12.0",
        "livewire/livewire": "^3.0",
        "blashbrook/papiclient": "*"
    },
    "autoload": {
        "psr-4": {
            "Dcplibrary\\Sfp\\": "src/",
            "Dcplibrary\\Sfp\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dcplibrary\\Sfp\\SfpServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
